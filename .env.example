# WordPress origin used for native/hybrid checkout redirects.
NEXT_PUBLIC_WORDPRESS_URL=https://your-wordpress-site.example

# GraphQL endpoint exposed by WPGraphQL (usually ${NEXT_PUBLIC_WORDPRESS_URL}/graphql).
NEXT_PUBLIC_WORDPRESS_GRAPHQL_URL=https://your-wordpress-site.example/graphql

# Legacy Vite-compatible aliases still referenced in parts of the migration scaffold.
VITE_WORDPRESS_URL=${NEXT_PUBLIC_WORDPRESS_URL}
VITE_WORDPRESS_GRAPHQL_URL=${NEXT_PUBLIC_WORDPRESS_GRAPHQL_URL}

# Shared Faust secret: must match the Faust WordPress plugin secret.
FAUST_SECRET_KEY=replace-with-a-long-random-shared-secret

# WooGraphQL session/auth conventions used by the storefront integration.
# Session token is returned in the `woocommerce-session` response header and
# persisted in localStorage under the same key before subsequent cart calls.
NEXT_PUBLIC_WOOGRAPHQL_SESSION_HEADER=woocommerce-session
NEXT_PUBLIC_WOOGRAPHQL_SESSION_STORAGE_KEY=woocommerce-session

# Optional bearer token for authenticated customer operations when using
# WPGraphQL JWT Auth or equivalent auth middleware.
NEXT_PUBLIC_WOOGRAPHQL_AUTH_TOKEN=
